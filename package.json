{
  "name": "pcl-context",
  "version": "1.0.0",
  "description": "Persistent Context Layer - 让 AI 记住你的一切",
  "type": "module",
  "bin": {
    "pcl": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "find-up": "^8.0.0",
    "flexsearch": "^0.7.43",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ai",
    "context",
    "mcp",
    "cli",
    "memory",
    "productivity"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/yourname/pcl-context"
  }
}
